{
  "name": "ttl-language",
  "displayName": "TTL - Tera Term Language",
  "description": "TTL (Tera Term Language) language support: syntax highlighting, completions, hover docs, and label navigation.",
  "version": "0.1.0",
  "publisher": "ttl-lsp",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "ttl",
    "teraterm",
    "tera term",
    "macro"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ttl",
        "aliases": [
          "TTL",
          "Tera Term Language"
        ],
        "extensions": [
          ".ttl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ttl",
        "scopeName": "source.ttl",
        "path": "./syntaxes/ttl.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "TTL Language",
      "properties": {
        "ttl.language": {
          "type": "string",
          "enum": [
            "auto",
            "ja",
            "en"
          ],
          "enumDescriptions": [
            "Detect language from VS Code UI setting",
            "Always show Japanese documentation",
            "Always show English documentation"
          ],
          "default": "auto",
          "description": "Language for hover documentation. 'auto' uses the VS Code display language."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:integration": "npm run compile:test && node ./out/test/runTest.js"
  },
  "overrides": {
    "serialize-javascript": "7.0.5"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.41",
    "@types/vscode": "1.120.0",
    "@vscode/test-electron": "2.5.2",
    "mocha": "11.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
