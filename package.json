{
  "name": "ttl-language",
  "displayName": "TTL - Tera Term Language",
  "description": "TTL (Tera Term Language) language support: syntax highlighting, completions, hover docs, and label navigation.",
  "version": "0.0.3",
  "publisher": "ttl-lsp",
  "license": "MIT",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/86chan/vscode-ttl.git"
  },
  "keywords": [
    "ttl",
    "teraterm",
    "tera term",
    "macro"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ttl",
        "aliases": [
          "TTL",
          "Tera Term Language"
        ],
        "extensions": [
          ".ttl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ttl",
        "scopeName": "source.ttl",
        "path": "./syntaxes/ttl.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "ttl",
        "label": "TTL Macro (Tera Term)",
        "languages": [
          "ttl"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "%ttl.dbg.program%",
                "default": "${file}"
              },
              "connect": {
                "type": "object",
                "description": "%ttl.dbg.connect%",
                "properties": {
                  "proto": {
                    "type": "string",
                    "enum": [
                      "ssh",
                      "telnet",
                      "serial",
                      "namedpipe"
                    ],
                    "enumDescriptions": [
                      "%ttl.dbg.connect.proto.ssh%",
                      "%ttl.dbg.connect.proto.telnet%",
                      "%ttl.dbg.connect.proto.serial%",
                      "%ttl.dbg.connect.proto.namedpipe%"
                    ],
                    "description": "%ttl.dbg.connect.proto%"
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "%ttl.dbg.connect.options%"
                  }
                },
                "allOf": [
                  {
                    "if": {
                      "required": [
                        "proto"
                      ],
                      "properties": {
                        "proto": {
                          "enum": [
                            "ssh",
                            "telnet"
                          ]
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "host": {
                          "type": "string",
                          "description": "%ttl.dbg.connect.host%"
                        },
                        "port": {
                          "type": "number",
                          "description": "%ttl.dbg.connect.port%"
                        },
                        "timeout": {
                          "type": "number",
                          "description": "%ttl.dbg.connect.timeout%"
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "proto"
                      ],
                      "properties": {
                        "proto": {
                          "const": "telnet"
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "binary": {
                          "type": "boolean",
                          "description": "%ttl.dbg.connect.binary%"
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "proto"
                      ],
                      "properties": {
                        "proto": {
                          "const": "serial"
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "comport": {
                          "type": "number",
                          "minimum": 1,
                          "maximum": 256,
                          "description": "%ttl.dbg.connect.comport%"
                        },
                        "speed": {
                          "type": "number",
                          "description": "%ttl.dbg.connect.speed%"
                        },
                        "cdatabit": {
                          "type": "number",
                          "enum": [
                            7,
                            8
                          ],
                          "description": "%ttl.dbg.connect.cdatabit%"
                        },
                        "cparity": {
                          "type": "string",
                          "enum": [
                            "none",
                            "odd",
                            "even",
                            "mark",
                            "space"
                          ],
                          "description": "%ttl.dbg.connect.cparity%"
                        },
                        "cstopbit": {
                          "type": "number",
                          "enum": [
                            1,
                            1.5,
                            2
                          ],
                          "description": "%ttl.dbg.connect.cstopbit%"
                        },
                        "cflowctrl": {
                          "type": "string",
                          "enum": [
                            "x",
                            "hard",
                            "none",
                            "rtscts",
                            "dsrdtr"
                          ],
                          "description": "%ttl.dbg.connect.cflowctrl%"
                        },
                        "cdelayperchar": {
                          "type": "number",
                          "description": "%ttl.dbg.connect.cdelayperchar%"
                        },
                        "cdelayperline": {
                          "type": "number",
                          "description": "%ttl.dbg.connect.cdelayperline%"
                        },
                        "waitcom": {
                          "type": "boolean",
                          "description": "%ttl.dbg.connect.waitcom%"
                        }
                      }
                    }
                  },
                  {
                    "if": {
                      "required": [
                        "proto"
                      ],
                      "properties": {
                        "proto": {
                          "const": "namedpipe"
                        }
                      }
                    },
                    "then": {
                      "properties": {
                        "host": {
                          "type": "string",
                          "description": "%ttl.dbg.connect.host%"
                        }
                      }
                    }
                  }
                ],
                "unevaluatedProperties": false
              },
              "windowTitle": {
                "type": "string",
                "description": "%ttl.dbg.windowTitle%"
              },
              "setupFile": {
                "type": "string",
                "description": "%ttl.dbg.setupFile%"
              },
              "keyboardFile": {
                "type": "string",
                "description": "%ttl.dbg.keyboardFile%"
              },
              "logFile": {
                "type": "string",
                "description": "%ttl.dbg.logFile%"
              },
              "noLog": {
                "type": "boolean",
                "description": "%ttl.dbg.noLog%"
              },
              "replayFile": {
                "type": "string",
                "description": "%ttl.dbg.replayFile%"
              },
              "fileTransferDir": {
                "type": "string",
                "description": "%ttl.dbg.fileTransferDir%"
              },
              "theme": {
                "type": "string",
                "description": "%ttl.dbg.theme%"
              },
              "vtIcon": {
                "type": "string",
                "description": "%ttl.dbg.vtIcon%"
              },
              "tekIcon": {
                "type": "string",
                "description": "%ttl.dbg.tekIcon%"
              },
              "hideTitleBar": {
                "type": "boolean",
                "description": "%ttl.dbg.hideTitleBar%"
              },
              "iconify": {
                "type": "boolean",
                "description": "%ttl.dbg.iconify%"
              },
              "hidden": {
                "type": "boolean",
                "description": "%ttl.dbg.hidden%"
              },
              "windowX": {
                "type": "number",
                "description": "%ttl.dbg.windowX%"
              },
              "windowY": {
                "type": "number",
                "description": "%ttl.dbg.windowY%"
              },
              "kanjiReceive": {
                "type": "string",
                "description": "%ttl.dbg.kanjiReceive%"
              },
              "kanjiTransmit": {
                "type": "string",
                "description": "%ttl.dbg.kanjiTransmit%"
              },
              "multicastName": {
                "type": "string",
                "description": "%ttl.dbg.multicastName%"
              },
              "osc52": {
                "type": "string",
                "description": "%ttl.dbg.osc52%"
              },
              "autoWinClose": {
                "type": "boolean",
                "description": "%ttl.dbg.autoWinClose%"
              },
              "disableLocalEcho": {
                "type": "boolean",
                "description": "%ttl.dbg.disableLocalEcho%"
              },
              "newConnectionDialog": {
                "type": "boolean",
                "description": "%ttl.dbg.newConnectionDialog%"
              },
              "teraTermDir": {
                "type": "string",
                "description": "%ttl.dbg.teraTermDir%",
                "default": ""
              },
              "launcher": {
                "type": "string",
                "enum": [
                  "ttermpro",
                  "ttpmacro",
                  "ttpmacro-attach"
                ],
                "enumDescriptions": [
                  "%ttl.dbg.launcher.ttermpro%",
                  "%ttl.dbg.launcher.ttpmacro%",
                  "%ttl.dbg.launcher.ttpmacro-attach%"
                ],
                "default": "ttermpro",
                "description": "%ttl.dbg.launcher%"
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ttl",
            "request": "launch",
            "name": "Run TTL Macro",
            "program": "${file}",
            "connect": {
              "proto": "ssh",
              "host": "192.168.0.100",
              "port": 22
            }
          }
        ],
        "configurationSnippets": [
          {
            "label": "TTL: Run Macro (SSH)",
            "description": "Run the current TTL macro over SSH",
            "body": {
              "type": "ttl",
              "request": "launch",
              "name": "Run TTL Macro (SSH)",
              "program": "^\"\\${file}\"",
              "connect": {
                "proto": "ssh",
                "host": "192.168.0.100",
                "port": 22
              }
            }
          },
          {
            "label": "TTL: Run Macro (Serial)",
            "description": "Run the current TTL macro over a serial / COM port",
            "body": {
              "type": "ttl",
              "request": "launch",
              "name": "Run TTL Macro (Serial)",
              "program": "^\"\\${file}\"",
              "connect": {
                "proto": "serial",
                "comport": 1,
                "speed": 115200
              }
            }
          },
          {
            "label": "TTL: Run Macro via ttpmacro (SSH)",
            "description": "Run the current TTL macro via ttpmacro.exe with SSH connection injected by the extension",
            "body": {
              "type": "ttl",
              "request": "launch",
              "name": "Run TTL Macro via ttpmacro (SSH)",
              "launcher": "ttpmacro",
              "program": "^\"\\${file}\"",
              "connect": {
                "proto": "ssh",
                "host": "192.168.0.100",
                "port": 22
              }
            }
          },
          {
            "label": "TTL: Run Macro in existing Tera Term (ttpmacro-attach)",
            "description": "Run the current TTL macro in an already-running ttermpro.exe session via ttpmacro.exe /D=",
            "body": {
              "type": "ttl",
              "request": "launch",
              "name": "Run TTL Macro (attach)",
              "launcher": "ttpmacro-attach",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ],
    "commands": [
      {
        "command": "ttl.formatWorkspace",
        "title": "%ttl.command.formatWorkspace%",
        "category": "TTL"
      }
    ],
    "configuration": {
      "title": "TTL Language",
      "properties": {
        "ttl.format.normalizeOperatorSpacing": {
          "type": "boolean",
          "default": true,
          "description": "%ttl.config.format.normalizeOperatorSpacing%"
        },
        "ttl.format.alignCommentTables": {
          "type": "boolean",
          "default": true,
          "description": "%ttl.config.format.alignCommentTables%"
        },
        "ttl.format.maxConsecutiveBlankLines": {
          "type": "integer",
          "default": 1,
          "minimum": 0,
          "description": "%ttl.config.format.maxConsecutiveBlankLines%"
        },
        "ttl.language": {
          "type": "string",
          "enum": [
            "auto",
            "ja",
            "en"
          ],
          "enumDescriptions": [
            "%ttl.config.language.auto%",
            "%ttl.config.language.ja%",
            "%ttl.config.language.en%"
          ],
          "default": "auto",
          "description": "%ttl.config.language%"
        },
        "ttl.maxNestingDepth": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "description": "%ttl.config.maxNestingDepth%"
        },
        "ttl.includeRootDir": {
          "type": "string",
          "default": "",
          "description": "%ttl.config.includeRootDir%"
        },
        "ttl.requireLabelInSameFile": {
          "type": "boolean",
          "default": false,
          "description": "%ttl.config.requireLabelInSameFile%"
        },
        "ttl.diagnostics.undefinedLabel": {
          "type": "boolean",
          "default": true,
          "description": "%ttl.config.diagnostics.undefinedLabel%"
        },
        "ttl.diagnostics.unknownCommand": {
          "type": "boolean",
          "default": true,
          "description": "%ttl.config.diagnostics.unknownCommand%"
        },
        "ttl.diagnostics.duplicateLabel": {
          "type": "boolean",
          "default": true,
          "description": "%ttl.config.diagnostics.duplicateLabel%"
        },
        "ttl.diagnostics.includeNotFound": {
          "type": "boolean",
          "default": true,
          "description": "%ttl.config.diagnostics.includeNotFound%"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:integration": "npm run compile:test && node ./out/test/runTest.js"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "glob": "11.1.0"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "26.0.0",
    "@types/vscode": "1.125.0",
    "@vscode/test-electron": "3.0.0",
    "mocha": "11.7.6",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
