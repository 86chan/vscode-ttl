{
  "name": "ttl-language",
  "displayName": "TTL - Tera Term Language",
  "description": "TTL (Tera Term Language) language support: syntax highlighting, completions, hover docs, and label navigation.",
  "version": "0.0.3",
  "publisher": "ttl-lsp",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/86chan/vscode-ttl.git"
  },
  "keywords": [
    "ttl",
    "teraterm",
    "tera term",
    "macro"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ttl",
        "aliases": [
          "TTL",
          "Tera Term Language"
        ],
        "extensions": [
          ".ttl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ttl",
        "scopeName": "source.ttl",
        "path": "./syntaxes/ttl.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "ttl",
        "label": "TTL Macro (Tera Term)",
        "languages": [
          "ttl"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Macro (.ttl) file to run.",
                "default": "${file}"
              },
              "host": {
                "type": "string",
                "description": "Connection target, e.g. 192.168.1.10:22. Leave empty to let the macro connect itself.",
                "default": ""
              },
              "connectOptions": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "description": "Extra Tera Term connection options, e.g. [\"/ssh\", \"/auth=password\", \"/user=admin\"]. Used only when host is set.",
                "default": [
                  "/ssh"
                ]
              },
              "teraTermDir": {
                "type": "string",
                "description": "Directory containing ttermpro.exe. Auto-detected (e.g. C:\\Program Files\\teraterm5) when empty.",
                "default": ""
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ttl",
            "request": "launch",
            "name": "Run TTL Macro",
            "program": "${file}",
            "host": "",
            "connectOptions": [
              "/ssh"
            ]
          }
        ],
        "configurationSnippets": [
          {
            "label": "TTL: Run Macro (Tera Term)",
            "description": "Run the current TTL macro with Tera Term",
            "body": {
              "type": "ttl",
              "request": "launch",
              "name": "Run TTL Macro",
              "program": "^\"\\${file}\"",
              "host": "",
              "connectOptions": [
                "/ssh"
              ]
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "TTL Language",
      "properties": {
        "ttl.language": {
          "type": "string",
          "enum": [
            "auto",
            "ja",
            "en"
          ],
          "enumDescriptions": [
            "Detect language from VS Code UI setting",
            "Always show Japanese documentation",
            "Always show English documentation"
          ],
          "default": "auto",
          "description": "Language for hover documentation. 'auto' uses the VS Code display language."
        },
        "ttl.maxNestingDepth": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "description": "Maximum allowed block nesting depth before a warning is reported. Set to 0 to disable the check."
        },
        "ttl.diagnostics.undefinedLabel": {
          "type": "boolean",
          "default": true,
          "description": "Warn when goto/call references a label with no matching definition (includes are resolved). Suppressed automatically when an included file cannot be resolved."
        },
        "ttl.diagnostics.unknownCommand": {
          "type": "boolean",
          "default": true,
          "description": "Warn when a line starts with an unknown command, suggesting the closest known command."
        },
        "ttl.diagnostics.duplicateLabel": {
          "type": "boolean",
          "default": true,
          "description": "Warn when the same label is defined more than once."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:integration": "npm run compile:test && node ./out/test/runTest.js"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "glob": "11.1.0"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.41",
    "@types/vscode": "1.120.0",
    "@vscode/test-electron": "2.5.2",
    "mocha": "11.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
