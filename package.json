{
  "name": "ttl-language",
  "displayName": "TTL - Tera Term Language",
  "description": "TTL (Tera Term Language) language support: syntax highlighting, completions, hover docs, and label navigation.",
  "version": "0.0.3",
  "publisher": "ttl-lsp",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/86chan/vscode-ttl.git"
  },
  "keywords": [
    "ttl",
    "teraterm",
    "tera term",
    "macro"
  ],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ttl",
        "aliases": [
          "TTL",
          "Tera Term Language"
        ],
        "extensions": [
          ".ttl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ttl",
        "scopeName": "source.ttl",
        "path": "./syntaxes/ttl.tmLanguage.json"
      }
    ],
    "debuggers": [
      {
        "type": "ttl",
        "label": "TTL Macro (Tera Term)",
        "languages": [
          "ttl"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Macro (.ttl) file to run.",
                "default": "${file}"
              },
              "connect": {
                "type": "object",
                "description": "Connection settings, translated to Tera Term command-line options. Omit to let the macro connect itself.",
                "properties": {
                  "proto": {
                    "type": "string",
                    "enum": [
                      "ssh",
                      "telnet",
                      "console"
                    ],
                    "enumDescriptions": [
                      "SSH (TCP/IP)",
                      "Telnet (TCP/IP)",
                      "Serial / COM port"
                    ],
                    "description": "Connection protocol (console = serial)."
                  },
                  "host": {
                    "type": "string",
                    "description": "Host name or address (ssh / telnet)."
                  },
                  "port": {
                    "type": "number",
                    "description": "TCP port (ssh / telnet)."
                  },
                  "comport": {
                    "type": "number",
                    "minimum": 1,
                    "maximum": 256,
                    "description": "Serial COM port number (console)."
                  },
                  "speed": {
                    "type": "number",
                    "description": "Serial baud rate (console)."
                  },
                  "cdatabit": {
                    "type": "number",
                    "enum": [
                      7,
                      8
                    ],
                    "description": "Serial data bits (console)."
                  },
                  "cparity": {
                    "type": "string",
                    "enum": [
                      "none",
                      "odd",
                      "even",
                      "mark",
                      "space"
                    ],
                    "description": "Serial parity (console)."
                  },
                  "cstopbit": {
                    "type": "number",
                    "enum": [
                      1,
                      1.5,
                      2
                    ],
                    "description": "Serial stop bits (console)."
                  },
                  "cflowctrl": {
                    "type": "string",
                    "enum": [
                      "x",
                      "hard",
                      "none",
                      "rtscts",
                      "dsrdtr"
                    ],
                    "description": "Serial flow control (console)."
                  },
                  "cdelayperchar": {
                    "type": "number",
                    "description": "Per-character delay in ms (console)."
                  },
                  "cdelayperline": {
                    "type": "number",
                    "description": "Per-line delay in ms (console)."
                  },
                  "options": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    },
                    "description": "Extra raw Tera Term options appended as-is, e.g. [\"/auth=password\", \"/user=admin\"]."
                  }
                }
              },
              "teraTermDir": {
                "type": "string",
                "description": "Directory containing ttermpro.exe. Auto-detected (e.g. C:\\Program Files\\teraterm5) when empty.",
                "default": ""
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ttl",
            "request": "launch",
            "name": "Run TTL Macro",
            "program": "${file}",
            "connect": {
              "proto": "ssh",
              "host": "192.168.0.100",
              "port": 22
            }
          }
        ],
        "configurationSnippets": [
          {
            "label": "TTL: Run Macro (SSH)",
            "description": "Run the current TTL macro over SSH",
            "body": {
              "type": "ttl",
              "request": "launch",
              "name": "Run TTL Macro (SSH)",
              "program": "^\"\\${file}\"",
              "connect": {
                "proto": "ssh",
                "host": "192.168.0.100",
                "port": 22
              }
            }
          },
          {
            "label": "TTL: Run Macro (Serial)",
            "description": "Run the current TTL macro over a serial / COM port",
            "body": {
              "type": "ttl",
              "request": "launch",
              "name": "Run TTL Macro (Serial)",
              "program": "^\"\\${file}\"",
              "connect": {
                "proto": "console",
                "comport": 1,
                "speed": 115200
              }
            }
          }
        ]
      }
    ],
    "configuration": {
      "title": "TTL Language",
      "properties": {
        "ttl.language": {
          "type": "string",
          "enum": [
            "auto",
            "ja",
            "en"
          ],
          "enumDescriptions": [
            "Detect language from VS Code UI setting",
            "Always show Japanese documentation",
            "Always show English documentation"
          ],
          "default": "auto",
          "description": "Language for hover documentation. 'auto' uses the VS Code display language."
        },
        "ttl.maxNestingDepth": {
          "type": "integer",
          "default": 2,
          "minimum": 0,
          "description": "Maximum allowed block nesting depth before a warning is reported. Set to 0 to disable the check."
        },
        "ttl.diagnostics.undefinedLabel": {
          "type": "boolean",
          "default": true,
          "description": "Warn when goto/call references a label with no matching definition (includes are resolved). Suppressed automatically when an included file cannot be resolved."
        },
        "ttl.diagnostics.unknownCommand": {
          "type": "boolean",
          "default": true,
          "description": "Warn when a line starts with an unknown command, suggesting the closest known command."
        },
        "ttl.diagnostics.duplicateLabel": {
          "type": "boolean",
          "default": true,
          "description": "Warn when the same label is defined more than once."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "compile:test": "tsc -p ./tsconfig.test.json",
    "watch": "tsc -watch -p ./",
    "test": "vitest run",
    "test:integration": "npm run compile:test && node ./out/test/runTest.js"
  },
  "overrides": {
    "serialize-javascript": "7.0.5",
    "glob": "11.1.0"
  },
  "devDependencies": {
    "@types/mocha": "10.0.10",
    "@types/node": "20.19.41",
    "@types/vscode": "1.120.0",
    "@vscode/test-electron": "2.5.2",
    "mocha": "11.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
